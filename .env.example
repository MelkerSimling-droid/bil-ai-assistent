# Krävs för riktiga AI-svar i chatten (Buster) och AI-sammanfattning av leads.
# Saknas nyckeln faller appen tillbaka på enkla mock-svar - se lib/ai.ts.
OPENAI_API_KEY=

# Valfri: koppla på Waykes officiella Search API (kräver nyckel från Wayke
# Support). Saknas den används redan skrapad data i data/bilar.json.
# Se lib/wayke.ts.
WAYKE_API_KEY=

# Valfri: koppla på en riktig teknisk datakälla (t.ex. car.info) för
# specifikationer som inte finns i Wayke-datan. Se lib/carInfo.ts.
CAR_INFO_API_KEY=

# Krävs för att komma åt /admin (leadvyn). Utan den svarar /admin 503.
# Se proxy.ts. Byt gärna till ett eget lösenord.
ADMIN_PASSWORD=
